# ============================================
# LinkUp - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ============================================

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# IMPORTANT: The service role key is REQUIRED for the app to work.
# Without it, login, registration, and profile saves will fail.
# Get it from: Supabase Dashboard → Settings → API → service_role (secret) key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Cloudinary (OPTIONAL — needed only for photo uploads) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- M-Pesa Daraja API (OPTIONAL — needed only for payments) ---
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.streamlit.app/mpesa/callback

# --- App Config ---
APP_SECRET_KEY=change-this-to-a-random-secret
APP_ENV=development
APP_NAME=LinkUp
APP_URL=http://localhost:8501
